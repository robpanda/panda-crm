{
  "name": "@panda-crm/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:root",
    "dev:root": "vite",
    "dev:analytics": "vite --config vite.analytics.config.js",
    "build": "npm run build:root",
    "build:root": "vite build",
    "build:analytics": "vite build --config vite.analytics.config.js && node ../scripts/release/write-analytics-release-manifest.mjs",
    "preview": "npm run preview:root",
    "preview:root": "vite preview",
    "preview:analytics": "vite preview --config vite.analytics.config.js",
    "check:blast-radius:analytics": "node ../scripts/release/check-analytics-blast-radius.mjs",
    "smoke:analytics:dist": "node ../scripts/release/smoke-analytics-dist.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.1",
    "@tanstack/react-query": "^5.8.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
